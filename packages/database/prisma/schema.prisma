generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OnboardingStatus {
  wallet_pending
  credentials_pending
  credentials_validating
  ready
  blocked
}

enum CredentialValidationStatus {
  pending
  validating
  valid
  invalid
  error
}

enum CredentialLifecycleStatus {
  pending
  active
  replaced
}

enum BotStatus {
  inactive
  active
  paused
  syncing
  error
}

enum PacificaConnectionStatus {
  disconnected
  connecting
  connected
  degraded
  error
}

enum ExchangeSnapshotStatus {
  confirmed
  last_known
}

enum SyncStatus {
  idle
  syncing
  healthy
  degraded
  error
}

enum PresetActivationStatus {
  pending
  active
  paused
  stopped
  failed
}

enum PositionSizeType {
  fixed_amount
  balance_percent
}

enum CommandType {
  validate_credentials
  activate_preset
  pause_bot
  resume_bot
  close_trade
}

enum SignalDecisionStatus {
  pending
  processing
  completed
  failed
  cancelled
}

enum CommandStatus {
  pending
  running
  completed
  failed
  cancelled
}

enum TargetType {
  credential
  preset_activation
  trade
  bot
}

enum TradeStatus {
  open
  close_requested
  closing
  sync_error
}

enum TradeSide {
  long
  short
}

enum CloseReason {
  take_profit
  stop_loss
  manual
  system
  error
}

enum AlertType {
  connection
  runtime
  reconciliation
  command
}

enum AlertSeverity {
  info
  warning
  error
}

enum OperationalEventType {
  credential_validation
  operational_verification
  signal_evaluation
  order_execution
  preset_activation
  bot_command
  runtime_reconciliation
}

enum OrderExecutionStatus {
  pending
  sent
  failed
}

enum MarketSnapshotStatus {
  confirmed
  stale
  unavailable
}

enum MarketPriceSource {
  market
  mark
}

model OperatorAccount {
  id                       String                    @id @default(uuid()) @db.Uuid
  walletAddress            String                    @unique
  onboardingStatus         OnboardingStatus
  createdAt                DateTime                  @default(now()) @db.Timestamptz(6)
  updatedAt                DateTime                  @updatedAt @db.Timestamptz(6)
  pacificaCredentials      PacificaCredential[]
  presetActivations        PresetActivation[]
  botRuntimeState          BotRuntimeState?
  botCommands              BotCommand[]
  openTrades               OpenTrade[]
  closedTrades             ClosedTrade[]
  accountBalanceSnapshots  AccountBalanceSnapshot[]
  operationalAlerts        OperationalAlert[]
  operationalEvents        OperationalEvent[]
  signalDecisions          SignalDecision[]
  orderExecutionAttempts   OrderExecutionAttempt[]
  symbolOperationalConfigs SymbolOperationalConfig[]
  yourStrategy             YourStrategy?
}

model PacificaCredential {
  id                        String                     @id @default(uuid()) @db.Uuid
  operatorAccountId         String?                    @db.Uuid
  walletAddress             String?
  credentialAlias           String?
  publicKey                 String
  encryptedPrivateKeyRef    String
  keyFingerprint            String
  validationStatus          CredentialValidationStatus
  lifecycleStatus           CredentialLifecycleStatus  @default(pending)
  operationallyVerified     Boolean                    @default(false)
  lastValidatedAt           DateTime?                  @db.Timestamptz(6)
  lastValidationErrorCode   String?
  lastOperationalVerifiedAt DateTime?                  @db.Timestamptz(6)
  lastOperationalErrorCode  String?
  lastOperationalProbeJson  Json?
  createdAt                 DateTime                   @default(now()) @db.Timestamptz(6)
  updatedAt                 DateTime                   @updatedAt @db.Timestamptz(6)
  operatorAccount           OperatorAccount?           @relation(fields: [operatorAccountId], references: [id], onDelete: Cascade)

  @@index([operatorAccountId])
  @@index([walletAddress])
  @@index([operatorAccountId, lifecycleStatus])
}

model PresetDefinition {
  id                String             @id @default(uuid()) @db.Uuid
  name              String
  slug              String             @unique
  version           Int
  riskLabel         String
  frequencyLabel    String
  description       String
  baseContractJson  Json
  isActive          Boolean
  createdAt         DateTime           @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime           @updatedAt @db.Timestamptz(6)
  presetActivations PresetActivation[]
}

model PresetActivation {
  id                     String                  @id @default(uuid()) @db.Uuid
  operatorAccountId      String                  @db.Uuid
  presetDefinitionId     String                  @db.Uuid
  activationStatus       PresetActivationStatus
  symbol                 String
  positionSizeType       PositionSizeType
  positionSizeValue      Decimal                 @db.Decimal(24, 8)
  longEnabled            Boolean
  shortEnabled           Boolean
  editableConfigJson     Json?
  effectiveContractJson  Json
  activatedAt            DateTime?               @db.Timestamptz(6)
  deactivatedAt          DateTime?               @db.Timestamptz(6)
  createdBy              String
  createdAt              DateTime                @default(now()) @db.Timestamptz(6)
  updatedAt              DateTime                @updatedAt @db.Timestamptz(6)
  operatorAccount        OperatorAccount         @relation(fields: [operatorAccountId], references: [id], onDelete: Cascade)
  presetDefinition       PresetDefinition        @relation(fields: [presetDefinitionId], references: [id])
  openTrades             OpenTrade[]
  closedTrades           ClosedTrade[]
  activeInRuntime        BotRuntimeState[]
  signalDecisions        SignalDecision[]
  orderExecutionAttempts OrderExecutionAttempt[]

  @@index([operatorAccountId])
  @@index([activationStatus])
  @@index([operatorAccountId, activationStatus])
}

model BotRuntimeState {
  id                       String                   @id @default(uuid()) @db.Uuid
  operatorAccountId        String                   @unique @db.Uuid
  botStatus                BotStatus
  pacificaConnectionStatus PacificaConnectionStatus
  syncStatus               SyncStatus
  exchangeSnapshotStatus   ExchangeSnapshotStatus   @default(last_known)
  exchangeLastSyncedAt     DateTime?                @db.Timestamptz(6)
  exchangeSnapshotMessage  String?
  activePresetActivationId String?                  @db.Uuid
  workerOwnerId            String?
  workerLeaseExpiresAt     DateTime?                @db.Timestamptz(6)
  workerLoopStartedAt      DateTime?                @db.Timestamptz(6)
  lastHeartbeatAt          DateTime?                @db.Timestamptz(6)
  lastSignalEvaluationAt   DateTime?                @db.Timestamptz(6)
  lastSignalFingerprint    String?
  lastErrorMessage         String?
  createdAt                DateTime                 @default(now()) @db.Timestamptz(6)
  updatedAt                DateTime                 @updatedAt @db.Timestamptz(6)
  operatorAccount          OperatorAccount          @relation(fields: [operatorAccountId], references: [id], onDelete: Cascade)
  activePresetActivation   PresetActivation?        @relation(fields: [activePresetActivationId], references: [id])

  @@index([workerOwnerId, workerLeaseExpiresAt])
}

model SymbolOperationalConfig {
  id                String          @id @default(uuid()) @db.Uuid
  operatorAccountId String          @db.Uuid
  symbol            String
  leverage          Decimal         @db.Decimal(12, 4)
  createdAt         DateTime        @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime        @updatedAt @db.Timestamptz(6)
  operatorAccount   OperatorAccount @relation(fields: [operatorAccountId], references: [id], onDelete: Cascade)

  @@unique([operatorAccountId, symbol])
  @@index([operatorAccountId])
}

model YourStrategy {
  id                        String          @id @default(uuid()) @db.Uuid
  operatorAccountId         String          @unique @db.Uuid
  draftJson                 Json
  materializedContractJson  Json?
  activationBlockersJson    Json?
  createdAt                 DateTime        @default(now()) @db.Timestamptz(6)
  updatedAt                 DateTime        @updatedAt @db.Timestamptz(6)
  operatorAccount           OperatorAccount @relation(fields: [operatorAccountId], references: [id], onDelete: Cascade)

  @@index([operatorAccountId])
}

model SignalDecision {
  id                     String                  @id @default(uuid()) @db.Uuid
  operatorAccountId      String                  @db.Uuid
  presetActivationId     String                  @db.Uuid
  signalFingerprint      String
  decisionStatus         SignalDecisionStatus
  signalSide             TradeSide
  symbol                 String
  marketSymbol           String
  timeframe              String
  priceSource            String
  candleOpenTime         DateTime                @db.Timestamptz(6)
  candleCloseTime        DateTime                @db.Timestamptz(6)
  entryReferencePrice    Decimal                 @db.Decimal(24, 8)
  stopLossPrice          Decimal                 @db.Decimal(24, 8)
  takeProfitPrice        Decimal                 @db.Decimal(24, 8)
  riskDistance           Decimal                 @db.Decimal(24, 8)
  payloadJson            Json?
  requestedAt            DateTime                @db.Timestamptz(6)
  createdAt              DateTime                @default(now()) @db.Timestamptz(6)
  updatedAt              DateTime                @updatedAt @db.Timestamptz(6)
  operatorAccount        OperatorAccount         @relation(fields: [operatorAccountId], references: [id], onDelete: Cascade)
  presetActivation       PresetActivation        @relation(fields: [presetActivationId], references: [id], onDelete: Cascade)
  orderExecutionAttempts OrderExecutionAttempt[]

  @@index([decisionStatus])
  @@index([operatorAccountId, requestedAt(sort: Desc)])
  @@index([presetActivationId, requestedAt(sort: Desc)])
  @@index([operatorAccountId, signalFingerprint, decisionStatus])
}

model OrderExecutionAttempt {
  id                   String               @id @default(uuid()) @db.Uuid
  operatorAccountId    String               @db.Uuid
  presetActivationId   String               @db.Uuid
  signalDecisionId     String               @db.Uuid
  executionStatus      OrderExecutionStatus
  clientOrderId        String               @unique
  signalFingerprint    String
  symbol               String
  marketSymbol         String
  orderSide            TradeSide
  requestedNotionalUsd Decimal              @db.Decimal(24, 8)
  requestedQuantity    Decimal              @db.Decimal(24, 8)
  entryReferencePrice  Decimal              @db.Decimal(24, 8)
  slippagePercent      Decimal              @db.Decimal(24, 8)
  requestJson          Json?
  responseJson         Json?
  failureReason        String?
  retryableFailure     Boolean              @default(false)
  pacificaOrderId      String?
  requestedAt          DateTime             @db.Timestamptz(6)
  finishedAt           DateTime?            @db.Timestamptz(6)
  createdAt            DateTime             @default(now()) @db.Timestamptz(6)
  updatedAt            DateTime             @updatedAt @db.Timestamptz(6)
  operatorAccount      OperatorAccount      @relation(fields: [operatorAccountId], references: [id], onDelete: Cascade)
  presetActivation     PresetActivation     @relation(fields: [presetActivationId], references: [id], onDelete: Cascade)
  signalDecision       SignalDecision       @relation(fields: [signalDecisionId], references: [id], onDelete: Cascade)

  @@index([operatorAccountId, requestedAt(sort: Desc)])
  @@index([signalDecisionId, requestedAt(sort: Desc)])
  @@index([executionStatus, requestedAt(sort: Desc)])
}

model BotCommand {
  id                String          @id @default(uuid()) @db.Uuid
  operatorAccountId String          @db.Uuid
  commandType       CommandType
  targetType        TargetType?
  targetId          String?         @db.Uuid
  payloadJson       Json?
  requestedBy       String
  commandStatus     CommandStatus
  idempotencyKey    String          @unique
  requestedAt       DateTime        @db.Timestamptz(6)
  startedAt         DateTime?       @db.Timestamptz(6)
  finishedAt        DateTime?       @db.Timestamptz(6)
  failureReason     String?
  createdAt         DateTime        @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime        @updatedAt @db.Timestamptz(6)
  operatorAccount   OperatorAccount @relation(fields: [operatorAccountId], references: [id], onDelete: Cascade)
  closedTrades      ClosedTrade[]

  @@index([commandStatus])
  @@index([operatorAccountId, requestedAt(sort: Desc)])
  @@index([targetType, targetId])
}

model OpenTrade {
  id                 String            @id @default(uuid()) @db.Uuid
  operatorAccountId  String            @db.Uuid
  pacificaTradeId    String
  presetActivationId String?           @db.Uuid
  stopLossPrice      Decimal?          @db.Decimal(24, 8)
  takeProfitPrice    Decimal?          @db.Decimal(24, 8)
  entryClientOrderId String?
  pacificaOrderId    String?
  symbol             String
  side               TradeSide
  entryPrice         Decimal           @db.Decimal(24, 8)
  currentPrice       Decimal           @db.Decimal(24, 8)
  quantity           Decimal           @db.Decimal(24, 8)
  capitalAllocated   Decimal           @db.Decimal(24, 8)
  unrealizedPnl      Decimal           @db.Decimal(24, 8)
  tradeStatus        TradeStatus
  openedAt           DateTime          @db.Timestamptz(6)
  closeRequestedAt   DateTime?         @db.Timestamptz(6)
  closeReasonPending CloseReason?
  isPlatformTrade    Boolean
  lastSyncedAt       DateTime          @db.Timestamptz(6)
  createdAt          DateTime          @default(now()) @db.Timestamptz(6)
  updatedAt          DateTime          @updatedAt @db.Timestamptz(6)
  operatorAccount    OperatorAccount   @relation(fields: [operatorAccountId], references: [id], onDelete: Cascade)
  presetActivation   PresetActivation? @relation(fields: [presetActivationId], references: [id])

  @@unique([operatorAccountId, pacificaTradeId])
  @@index([operatorAccountId])
  @@index([tradeStatus])
  @@index([operatorAccountId, openedAt(sort: Desc)])
}

model ClosedTrade {
  id                 String            @id @default(uuid()) @db.Uuid
  operatorAccountId  String            @db.Uuid
  pacificaTradeId    String
  presetActivationId String?           @db.Uuid
  symbol             String
  side               TradeSide
  entryPrice         Decimal           @db.Decimal(24, 8)
  exitPrice          Decimal           @db.Decimal(24, 8)
  quantity           Decimal           @db.Decimal(24, 8)
  capitalAllocated   Decimal           @db.Decimal(24, 8)
  realizedPnl        Decimal           @db.Decimal(24, 8)
  closeReason        CloseReason
  openedAt           DateTime          @db.Timestamptz(6)
  closedAt           DateTime          @db.Timestamptz(6)
  isPlatformTrade    Boolean
  closedByCommandId  String?           @db.Uuid
  lastSyncedAt       DateTime          @db.Timestamptz(6)
  createdAt          DateTime          @default(now()) @db.Timestamptz(6)
  operatorAccount    OperatorAccount   @relation(fields: [operatorAccountId], references: [id], onDelete: Cascade)
  presetActivation   PresetActivation? @relation(fields: [presetActivationId], references: [id])
  closedByCommand    BotCommand?       @relation(fields: [closedByCommandId], references: [id])

  @@index([operatorAccountId, closedAt(sort: Desc)])
  @@index([presetActivationId])
  @@index([closeReason])
}

model AccountBalanceSnapshot {
  id                String          @id @default(uuid()) @db.Uuid
  operatorAccountId String          @db.Uuid
  totalBalance      Decimal         @db.Decimal(24, 8)
  availableBalance  Decimal         @db.Decimal(24, 8)
  aggregatedPnl     Decimal         @db.Decimal(24, 8)
  capitalInUse      Decimal         @db.Decimal(24, 8)
  capturedAt        DateTime        @db.Timestamptz(6)
  createdAt         DateTime        @default(now()) @db.Timestamptz(6)
  operatorAccount   OperatorAccount @relation(fields: [operatorAccountId], references: [id], onDelete: Cascade)

  @@index([operatorAccountId, capturedAt(sort: Desc)])
}

model OperationalAlert {
  id                String          @id @default(uuid()) @db.Uuid
  operatorAccountId String          @db.Uuid
  alertType         AlertType
  severity          AlertSeverity
  title             String
  message           String
  isActive          Boolean
  createdAt         DateTime        @default(now()) @db.Timestamptz(6)
  resolvedAt        DateTime?       @db.Timestamptz(6)
  operatorAccount   OperatorAccount @relation(fields: [operatorAccountId], references: [id], onDelete: Cascade)

  @@index([operatorAccountId, isActive])
  @@index([severity, createdAt(sort: Desc)])
}

model OperationalEvent {
  id                String               @id @default(uuid()) @db.Uuid
  operatorAccountId String?              @db.Uuid
  walletAddress     String?
  eventType         OperationalEventType
  severity          AlertSeverity
  title             String
  message           String
  payloadJson       Json?
  createdAt         DateTime             @default(now()) @db.Timestamptz(6)
  operatorAccount   OperatorAccount?     @relation(fields: [operatorAccountId], references: [id], onDelete: Cascade)

  @@index([operatorAccountId, createdAt(sort: Desc)])
  @@index([walletAddress, createdAt(sort: Desc)])
  @@index([eventType, createdAt(sort: Desc)])
}

model MarketPriceCurrent {
  symbol         String               @id
  markPrice      Decimal              @db.Decimal(24, 8)
  indexPrice     Decimal?             @db.Decimal(24, 8)
  lastPrice      Decimal?             @db.Decimal(24, 8)
  volume24h      Decimal?             @db.Decimal(24, 8)
  openInterest   Decimal?             @db.Decimal(24, 8)
  fundingRate    Decimal?             @db.Decimal(18, 12)
  capturedAt     DateTime             @db.Timestamptz(6)
  fetchedAt      DateTime             @db.Timestamptz(6)
  snapshotStatus MarketSnapshotStatus @default(confirmed)
  source         String
  createdAt      DateTime             @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime             @updatedAt @db.Timestamptz(6)

  @@index([fetchedAt(sort: Desc)])
}

model MarketCandleSnapshot {
  id             String               @id @default(uuid()) @db.Uuid
  symbol         String
  interval       String
  priceSource    MarketPriceSource
  openTime       DateTime             @db.Timestamptz(6)
  closeTime      DateTime             @db.Timestamptz(6)
  open           Decimal              @db.Decimal(24, 8)
  high           Decimal              @db.Decimal(24, 8)
  low            Decimal              @db.Decimal(24, 8)
  close          Decimal              @db.Decimal(24, 8)
  volume         Decimal              @db.Decimal(24, 8)
  fetchedAt      DateTime             @db.Timestamptz(6)
  snapshotStatus MarketSnapshotStatus @default(confirmed)
  source         String
  createdAt      DateTime             @default(now()) @db.Timestamptz(6)

  @@unique([symbol, interval, priceSource, openTime])
  @@index([symbol, interval, priceSource, openTime(sort: Desc)])
  @@index([fetchedAt(sort: Desc)])
}

model MarketInfoCurrent {
  symbol         String               @id
  tickSize       Decimal              @db.Decimal(24, 8)
  lotSize        Decimal              @db.Decimal(24, 8)
  minOrderSize   Decimal              @db.Decimal(24, 8)
  maxOrderSize   Decimal?             @db.Decimal(24, 8)
  maxLeverage    Decimal?             @db.Decimal(18, 8)
  fetchedAt      DateTime             @db.Timestamptz(6)
  snapshotStatus MarketSnapshotStatus @default(confirmed)
  source         String
  createdAt      DateTime             @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime             @updatedAt @db.Timestamptz(6)

  @@index([fetchedAt(sort: Desc)])
}

model MarketRefreshLog {
  id             String    @id @default(uuid()) @db.Uuid
  refreshType    String
  refreshKey     String
  startedAt      DateTime  @db.Timestamptz(6)
  finishedAt     DateTime? @db.Timestamptz(6)
  status         String
  errorMessage   String?
  recordsWritten Int       @default(0)
  createdAt      DateTime  @default(now()) @db.Timestamptz(6)

  @@index([refreshType, startedAt(sort: Desc)])
  @@index([refreshKey, startedAt(sort: Desc)])
}
