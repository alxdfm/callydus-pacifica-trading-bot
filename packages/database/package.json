{
  "name": "@pacifica/database",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "prisma:generate": "dotenv -e ../../.env -- prisma generate",
    "typecheck": "dotenv -e ../../.env -- prisma validate",
    "prisma:format": "dotenv -e ../../.env -- prisma format",
    "db:push": "dotenv -e ../../.env -- prisma db push",
    "migrate:dev": "dotenv -e ../../.env -- prisma migrate dev"
  },
  "devDependencies": {
    "prisma": "^6.5.0"
  },
  "dependencies": {
    "@prisma/client": "6.19.2"
  }
}
