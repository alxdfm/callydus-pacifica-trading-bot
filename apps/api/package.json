{
  "name": "@pacifica/api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "dotenv -e ../../.env -- tsx watch src/server.ts",
    "start": "dotenv -e ../../.env -- tsx src/server.ts",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config drizzle.config.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@noble/curves": "^1.4.2",
    "@pacifica/contracts": "workspace:*",
    "@pacifica/credential-crypto": "workspace:*",
    "@pacifica/pacifica-market-data": "workspace:*",
    "@pacifica/pacifica-trading": "workspace:*",
    "@pacifica/preset-engine": "workspace:*",
    "@prisma/client": "^6.19.2",
    "@types/ws": "^8.18.1",
    "bs58": "^6.0.0",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.9",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.161",
    "@types/node": "^24.5.2",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3"
  }
}
