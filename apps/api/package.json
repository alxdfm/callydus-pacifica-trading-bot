{
  "name": "@pacifica/api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "cleanup:market-data": "dotenv -e ../../.env -- tsx src/scripts/cleanupMarketData.ts",
    "dev": "dotenv -e ../../.env -- tsx watch src/server.ts",
    "refresh:market-data": "dotenv -e ../../.env -- tsx src/scripts/refreshMarketData.ts",
    "start": "dotenv -e ../../.env -- tsx src/server.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@noble/curves": "^1.4.2",
    "@pacifica/credential-crypto": "workspace:*",
    "@pacifica/contracts": "workspace:*",
    "@pacifica/pacifica-market-data": "workspace:*",
    "@pacifica/pacifica-trading": "workspace:*",
    "@pacifica/preset-engine": "workspace:*",
    "@prisma/client": "^6.19.2",
    "bs58": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3"
  }
}
