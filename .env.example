# Core
NODE_ENV=development
LOG_LEVEL=debug

# Local database
DATABASE_URL=postgresql://postgres:postgres@localhost:55432/pacifica

# Frontend -> API
VITE_APP_API_BASE_URL=http://localhost:3000
APP_ORIGIN=http://localhost:5173
VITE_PACIFICA_BUILDER_CODE=callydus
VITE_PACIFICA_BUILDER_MAX_FEE_RATE=0.007
VITE_PACIFICA_SIGNATURE_EXPIRY_WINDOW_MS=30000

# Pacifica
PACIFICA_ENV=mainnet
PACIFICA_REST_BASE_URL=https://api.pacifica.fi
PACIFICA_WS_URL=wss://ws.pacifica.fi/ws
PACIFICA_API_KEY=
PACIFICA_SIGNATURE_EXPIRY_WINDOW_MS=30000
PACIFICA_BUILDER_CODE=callydus
PACIFICA_BUILDER_MAX_FEE_RATE=0.007
# Diagnostic-only fallback for local validation experiments.
# Do not use as the default product flow.
PACIFICA_ACCOUNT_PRIVATE_KEY=

# Credentials and encryption
# Use a strong random secret in real environments.
CREDENTIAL_ENCRYPTION_KEY=dev-local-super-secret-key-please-change
CREDENTIAL_ENCRYPTION_KEY_ID=local-dev-v1
