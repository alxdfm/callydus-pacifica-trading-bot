# Core
NODE_ENV=development
LOG_LEVEL=debug

# Local database
DATABASE_URL=postgresql://postgres:postgres@localhost:55432/pacifica
DIRECT_DATABASE_URL=postgresql://postgres:postgres@localhost:55432/pacifica

# Frontend -> API
VITE_APP_API_BASE_URL=http://localhost:3003
APP_ORIGIN=http://localhost:5173
VITE_PACIFICA_BUILDER_CODE=callydus
VITE_PACIFICA_BUILDER_MAX_FEE_RATE=0.007
VITE_PACIFICA_SIGNATURE_EXPIRY_WINDOW_MS=30000

# Pacifica
PACIFICA_ENV=mainnet
PACIFICA_REST_BASE_URL=https://api.pacifica.fi
PACIFICA_WS_URL=wss://ws.pacifica.fi/ws
PACIFICA_API_KEY=
PACIFICA_SIGNATURE_EXPIRY_WINDOW_MS=30000
PACIFICA_BUILDER_CODE=callydus
PACIFICA_BUILDER_MAX_FEE_RATE=0.007
PACIFICA_OPERATIONAL_PROBE_SYMBOL=BTC
PACIFICA_OPERATIONAL_PROBE_PRICE=20000
PACIFICA_OPERATIONAL_PROBE_TARGET_NOTIONAL_USD=11
PACIFICA_OPERATIONAL_PROBE_TIF=ALO

# Worker runtime
WORKER_ID=worker-local-1
WORKER_SIGNAL_TRACE_ENABLED=false
WORKER_SCAN_INTERVAL_MS=5000
WORKER_HEARTBEAT_INTERVAL_MS=15000
WORKER_ANALYSIS_INTERVAL_MS=60000
WORKER_MARKET_ORDER_SLIPPAGE_PERCENT=0.5
WORKER_LEASE_DURATION_MS=45000
WORKER_MAX_BACKOFF_MS=30000

# Credentials and encryption
# CREDENTIAL_ENCRYPTION_KEY: use a strong random secret (min 32 chars) in real environments.
# CREDENTIAL_ENCRYPTION_KEY_ID: use "v2-<env>" (e.g. "v2-prod") to enable HKDF derivation.
#   IDs not starting with "v2" fall back to legacy SHA-256 derivation (backwards compat).
CREDENTIAL_ENCRYPTION_KEY=dev-local-super-secret-key-please-change
CREDENTIAL_ENCRYPTION_KEY_ID=local-dev-v1

# Internal API secret
# Protects POST /api/internal/market/refresh from unauthenticated callers.
# Use a strong random secret in real environments (e.g. openssl rand -hex 32).
INTERNAL_API_SECRET=dev-local-internal-secret-please-change

# Local market data refresh scheduler
LOCAL_MARKET_DATA_REFRESH_ENABLED=true
LOCAL_MARKET_DATA_REFRESH_INTERVAL_MS=60000
LOCAL_MARKET_DATA_REFRESH_RUN_ON_START=true
LOCAL_MARKET_DATA_REFRESH_PRICES=true
LOCAL_MARKET_DATA_REFRESH_MARKET_INFO=true
