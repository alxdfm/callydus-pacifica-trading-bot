# =============================================================================
# trading-bot-pacifica — variáveis de ambiente
# Copie este arquivo para .env e preencha os valores marcados como REQUIRED.
# Variáveis com valor padrão são opcionais em desenvolvimento.
# =============================================================================

# -----------------------------------------------------------------------------
# Banco de dados (compartilhado entre API e Worker)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pacifica

# -----------------------------------------------------------------------------
# Criptografia de credenciais (compartilhado entre API e Worker)
# CREDENTIAL_ENCRYPTION_KEY: string aleatória forte, mínimo 32 caracteres.
#   Gere com: openssl rand -hex 32
# CREDENTIAL_ENCRYPTION_KEY_ID: identificador da versão da chave.
#   IDs que começam com "v2" usam derivação HKDF; outros usam SHA-256 legado.
# -----------------------------------------------------------------------------
CREDENTIAL_ENCRYPTION_KEY=dev-local-super-secret-key-please-change   # REQUIRED
CREDENTIAL_ENCRYPTION_KEY_ID=local-dev-v1

# -----------------------------------------------------------------------------
# Assinatura dos tokens de sessão (API)
# AUTH_SIGNING_SECRET: segredo HMAC dos tokens de sessão, mínimo 32 caracteres.
#   Deve ser DIFERENTE de CREDENTIAL_ENCRYPTION_KEY — rotacionar sessões não
#   pode exigir re-criptografar credenciais. Gere com: openssl rand -hex 32
# -----------------------------------------------------------------------------
AUTH_SIGNING_SECRET=dev-local-auth-signing-secret-please-change      # REQUIRED

# -----------------------------------------------------------------------------
# Pacifica — configuração geral (compartilhado entre API e Worker)
# -----------------------------------------------------------------------------
PACIFICA_BUILDER_CODE=callydus          # REQUIRED
PACIFICA_BUILDER_MAX_FEE_RATE=0.007
PACIFICA_REST_BASE_URL=https://api.pacifica.fi
PACIFICA_SIGNATURE_EXPIRY_WINDOW_MS=30000

# -----------------------------------------------------------------------------
# API (packages/api) — servidor Hono
# -----------------------------------------------------------------------------
PORT=3003
APP_ORIGIN=http://localhost:5173

# Probe operacional: ordem-limite ALO usada para verificar se a agent wallet
# tem permissão de operar. A ordem é cancelada imediatamente após criação.
PACIFICA_OPERATIONAL_PROBE_SYMBOL=BTC
PACIFICA_OPERATIONAL_PROBE_PRICE=20000
PACIFICA_OPERATIONAL_PROBE_TARGET_NOTIONAL_USD=11
PACIFICA_OPERATIONAL_PROBE_TIF=ALO      # ALO | GTC | IOC

# -----------------------------------------------------------------------------
# Worker (packages/worker) — bot de trading
# -----------------------------------------------------------------------------
PACIFICA_WS_URL=wss://ws.pacifica.fi
WORKER_ID=worker-local-1

# Risco
MARKET_ORDER_SLIPPAGE_PERCENT=0.5
TAKER_FEE_PERCENT=0.05

# Cadência (valores em milissegundos)
SCAN_INTERVAL_MS=5000
HEARTBEAT_INTERVAL_MS=15000
ANALYSIS_INTERVAL_MS=60000
LEASE_DURATION_MS=45000
MAX_BACKOFF_MS=30000

# Logging detalhado de sinais — NUNCA habilitar em produção (expõe dados financeiros)
SIGNAL_TRACE_ENABLED=false

# -----------------------------------------------------------------------------
# Frontend (packages/frontend) — variáveis Vite (prefixo VITE_ obrigatório)
# -----------------------------------------------------------------------------
VITE_APP_API_BASE_URL=http://localhost:3003
VITE_PACIFICA_BUILDER_CODE=callydus     # deve ser igual a PACIFICA_BUILDER_CODE
VITE_PACIFICA_BUILDER_MAX_FEE_RATE=0.007
VITE_PACIFICA_SIGNATURE_EXPIRY_WINDOW_MS=30000
